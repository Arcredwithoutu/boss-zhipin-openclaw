{
  "id": "boss-zhipin",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "deliveryChannels": {
        "type": "array",
        "description": "推送渠道列表，未配置的渠道自动跳过",
        "items": { "type": "string", "enum": ["feishu", "wecom", "telegram"] },
        "default": ["feishu", "wecom", "telegram"]
      },
      "deliveryTarget": {
        "type": "object",
        "description": "各渠道推送目标 ID",
        "additionalProperties": false,
        "properties": {
          "feishu": { "type": "string" },
          "wecom": { "type": "string" },
          "telegram": { "type": "string" }
        }
      },
      "cronExpr": {
        "type": "string",
        "default": "0 */3 * * *",
        "description": "Cron 表达式，默认每3小时"
      },
      "cronTz": {
        "type": "string",
        "default": "Asia/Shanghai"
      }
    }
  }
}
